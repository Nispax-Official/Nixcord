{
  "manifest_version": 2,
  "name": "Nixcord",
  "version": "1.0.0",
  "description": "A performance-first Discord mod client by NISPAX InfoTech",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "https://discord.com/*"
  ],
  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "nixcord.js",
    "content/loader.js"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nixcord@nispax.in",
      "strict_min_version": "109.0"
    }
  }
}
